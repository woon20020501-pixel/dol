# Dol — Dashboard Environment Variables
# Copy to .env.local and fill in values

# RPC endpoint for on-chain reads (e.g. Base Sepolia)
NEXT_PUBLIC_RPC_URL=

# Bot Status API base URL
NEXT_PUBLIC_BOT_API_URL=http://localhost:7777

# Demo mode — uses 30-day average APY instead of live carry score
# Set to true for demo recording and production Vercel deployment
# Set to false for development to see real-time bot state
NEXT_PUBLIC_DEMO_MODE=false

# Chain ID for wallet connection (84532 = Base Sepolia)
NEXT_PUBLIC_CHAIN_ID=84532

# Privy app ID — required for wallet/email/social login
# Create at https://dashboard.privy.io and paste the app ID here
NEXT_PUBLIC_PRIVY_APP_ID=
