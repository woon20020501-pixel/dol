# Deployer wallet private key (never commit the real value)
DEPLOYER_PRIVATE_KEY=
# RPC endpoint for Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Alias used by foundry.toml rpc_endpoints (kept for backwards compat)
RPC_URL=
# Block-explorer API key for contract verification (Basescan)
ETHERSCAN_API_KEY=
# Bot's address — set as OPERATOR_ROLE at deploy time
OPERATOR_ADDRESS=
# governance address — set as GUARDIAN_ROLE at deploy time
GUARDIAN_ADDRESS=
# USDC token address on Base Sepolia (optional: if unset, deploys a mock)
USDC_ADDRESS=
